# ---- Telephony (Twilio) ----
# Get these from https://console.twilio.com after buying an Indian toll-free/local number
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_FROM_NUMBER=+91XXXXXXXXXX
# Public HTTPS base URL Twilio will call back to (ngrok URL for local dev, real domain in prod)
PUBLIC_BASE_URL=https://your-domain-or-ngrok-id.ngrok-free.app

# ---- Bhashini (ULCA / Dhruva) ----
# Register at https://bhashini.gov.in -> "My Profile" -> Generate API Key
BHASHINI_USER_ID=your_ulca_user_id
BHASHINI_ULCA_API_KEY=your_ulca_api_key
BHASHINI_PIPELINE_ID=64392f96daac500b55c543cd   # example NLP pipeline id; confirm current value from ULCA portal
BHASHINI_CONFIG_URL=https://meity-auth.ulcacontrib.org/ulca/apis/v0/model/getModelsPipeline

# ---- Database ----
DATABASE_URL=postgresql+psycopg2://voicesarkar:voicesarkar@db:5432/voicesarkar

# ---- Session store ----
REDIS_URL=redis://redis:6379/0

# ---- Internal/admin API protection ----
ADMIN_API_KEY=change-me-to-a-long-random-string

# ---- Portal submission mode ----
# mock   = simulate submission (safe default, no real portal contact)
# rpa    = attempt browser-automation submission (EXPERIMENTAL, needs legal sign-off, see README)
PORTAL_MODE=mock
